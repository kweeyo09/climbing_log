# Copy this file to .env and fill in your credentials

# Supabase — get from: supabase.com → Your Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Places — get from: console.cloud.google.com → APIs & Services → Credentials
# Enable "Places API" for your key
EXPO_PUBLIC_GOOGLE_PLACES_KEY=your-google-places-api-key-here
