{
  "expo": {
    "name": "SENDLOG",
    "slug": "sendlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kweeyo09.sendlog"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d0e"
      },
      "package": "com.kweeyo09.sendlog"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "sendlog",
    "experiments": {
      "typedRoutes": true
    }
  }
}
